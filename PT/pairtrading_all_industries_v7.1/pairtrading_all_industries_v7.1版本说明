def robust_halflife(spread, window=60, min_periods=30):
    """滚动计算Halflife，取中位数作为稳健估计"""
    halflives = []
    for i in range(window, len(spread)):
        hl = calculate_halflife(spread.iloc[i-window:i])
        if not np.isinf(hl) and hl > 0:
            halflives.append(hl)
    
    return np.median(halflives) if halflives else 15
