def filter_pairs_by_halflife(pairs, min_hl=2, max_hl=30):
    """
    根据Halflife筛选配对
    
    - 剔除Halflife < 2天：噪声交易，信号不稳定
    - 剔除Halflife > 30天：回归太慢，资金效率低
    """
    valid_pairs = []
    for pair in pairs:
        hl = pair['halflife']
        if min_hl <= hl <= max_hl:
            valid_pairs.append(pair)
        else:
            print(f"剔除 {pair['stock1']}-{pair['stock2']}: Halflife={hl:.1f}天")
    return valid_pairs
