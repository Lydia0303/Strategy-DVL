先看组合结构问题和夏普比率整体偏低（0.60）这两个问题

1、高波动的行业或者配对股票的交易很频繁，针对这个问题，每个行业根据自身的波动率情况适配不同的开仓平仓阈值以及轮动阈值，再根据均值回归速度决定持仓时间。

2、风险平价导致资金过度集中于低波动行业，形成"头重脚轻"结构。这里改用风险平价+收益调整（风险收益比）
优化一：自适应阈值系统（行业/配对级别）
核心思想
高波动行业 → 提高阈值、延长持仓、减少交易
低波动行业 → 降低阈值、缩短持仓、增加交易
实现方案
Python
class AdaptiveThresholdManager:
    """
    根据行业/配对特征动态调整交易参数
    """
    
    def __init__(self, base_params):
        self.base = base_params
        
    def calculate_adaptive_params(self, pair_data, in_sample_returns):
        """
        计算该配对的自适应参数
        """
        # 1. 计算波动率特征
        volatility = np.std(in_sample_returns) * np.sqrt(252)  # 年化波动
        
        # 2. 计算均值回归速度（Halflife）
        from statsmodels.tsa.ar_model import AutoReg
        try:
            model = AutoReg(in_sample_returns, lags=1).fit()
            rho = model.params[1]  # 自相关系数
            halflife = -np.log(2) / np.log(abs(rho)) if abs(rho) < 1 else 252
        except:
            halflife = 20  # 默认值
        
        # 3. 波动率分档
        if volatility > 0.35:      # 高波动（如证券、科技）
            vol_factor = 1.5
            hold_factor = 2.0
        elif volatility > 0.25:    # 中波动（如工业）
            vol_factor = 1.2
            hold_factor = 1.5
        elif volatility > 0.15:    # 低波动（如银行）
            vol_factor = 0.9
            hold_factor = 1.0
        else:                      # 极低波动
            vol_factor = 0.8
            hold_factor = 0.8
        
        # 4. 均值回归速度调整
        # 回归快（halflife短）→ 缩短持仓，快速止盈
        # 回归慢（halflife长）→ 延长持仓，耐心等待
        if halflife < 5:
            speed_factor = 0.7  # 快速回归，紧凑参数
        elif halflife < 15:
            speed_factor = 1.0  # 正常
        elif halflife < 30:
            speed_factor = 1.3  # 慢速回归，宽松参数
        else:
            speed_factor = 1.5  # 极慢回归，非常宽松
        
        return {
            'entry_threshold': self.base['entry_threshold'] * vol_factor,
            'exit_threshold': self.base['exit_threshold'] * vol_factor * 0.8,  # 出场相对更紧
            'stop_loss': self.base['stop_loss'] * vol_factor,
            'max_holding_days': int(self.base['max_holding_days'] * hold_factor * speed_factor),
            'rebalance_threshold': self.base['rebalance_threshold'] * vol_factor,
            'volatility': volatility,
            'halflife': halflife
        }
