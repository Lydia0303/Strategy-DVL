from sklearn.decomposition import PCA

def portfolio_halflife(returns, n_components=3):
    """计算组合主成分的Halflife"""
    pca = PCA(n_components=n_components)
    factors = pca.fit_transform(returns)
    
    hl_list = [calculate_halflife(pd.Series(factors[:, i])) 
               for i in range(n_components)]
    
    # 按解释方差加权
    weights = pca.explained_variance_ratio_
    weighted_hl = np.average([h for h in hl_list if not np.isinf(h)], 
                          weights=weights[:len(hl_list)])
    return weighted_hl
