import numpy as np
import pandas as pd
from statsmodels.regression.linear_model import OLS
from statsmodels.tools.tools import add_constant

def calculate_halflife(spread_series):
    """
    计算价差序列的均值回归半衰期
    
    Parameters:
    -----------
    spread_series : pd.Series
        价差序列（已对齐的）
    
    Returns:
    --------
    halflife : float
        半衰期（天数）
    """
    # 1. 准备数据
    spread = spread_series.dropna()
    
    # 2. 计算一阶差分（Δx_t）
    delta_spread = spread.diff().dropna()
    
    # 3. 滞后一期（x_{t-1}）
    lag_spread = spread.shift(1).dropna()
    
    # 4. 对齐索引
    valid_idx = delta_spread.index.intersection(lag_spread.index)
    y = delta_spread.loc[valid_idx]  # Δx_t
    X = lag_spread.loc[valid_idx]    # x_{t-1}
    
    # 5. AR(1)回归: Δx_t = α + β*x_{t-1} + ε
    X = add_constant(X)  # 添加常数项
    model = OLS(y, X).fit()
    
    # 6. 提取系数
    beta = model.params.iloc[1]  # x_{t-1}的系数
    
    # 7. 计算Halflife
    if beta >= 0:
        # β >= 0 表示非均值回归（发散或随机游走）
        return np.inf
    else:
        halflife = -np.log(2) / beta
        return halflife

